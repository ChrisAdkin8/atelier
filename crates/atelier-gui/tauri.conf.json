{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atelier",
  "version": "0.1.0",
  "identifier": "dev.atelier.app",
  "build": {
    "beforeDevCommand": {
      "cwd": "./ui",
      "script": "npm run dev"
    },
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": {
      "cwd": "./ui",
      "script": "npm run build"
    },
    "frontendDist": "./ui/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Atelier",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Atelier coding harness.",
    "longDescription": "Atelier is a bring-your-own-model coding harness. The Tauri shell consumes the atelier-core agent loop over a broadcast channel."
  }
}
