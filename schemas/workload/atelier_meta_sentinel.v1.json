{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atelier.example/schemas/workload/atelier_meta_sentinel.v1.json",
  "title": "Atelier-meta sentinel payload",
  "description": "Optional JSON block a harness may emit on stdout between <<<atelier-meta>>> ... <<<end>>> sentinels. The workload runner extracts it for telemetry.",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "turn_count": {"type": "integer", "minimum": 0},
    "tool_call_count": {"type": "integer", "minimum": 0},
    "permission_prompt_count": {"type": "integer", "minimum": 0},
    "tokens": {
      "type": "object",
      "properties": {
        "prompt": {"type": "integer", "minimum": 0},
        "completion": {"type": "integer", "minimum": 0},
        "cached": {"type": "integer", "minimum": 0}
      }
    },
    "cost_usd": {"type": "number"},
    "model_id": {"type": "string"}
  }
}
