{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atelier.example/schemas/protocol/overhead.v1.json",
  "title": "Model Protocol overhead measurements",
  "type": "object",
  "required": ["version", "measured_at", "providers"],
  "properties": {
    "version": {"const": 1, "description": "Schema version."},
    "measured_at": {"type": "string", "format": "date-time"},
    "providers": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["provider", "model_id", "strategy", "median_overhead_pct", "conformance_rate"],
        "properties": {
          "provider": {"type": "string"},
          "model_id": {"type": "string"},
          "strategy": {"enum": ["native_tool", "json_mode", "regex_prose"]},
          "median_overhead_pct": {
            "type": "number",
            "description": "Median percentage token overhead vs. a no-protocol baseline turn on the same task"
          },
          "conformance_rate": {
            "type": "number",
            "minimum": 0,
            "maximum": 1,
            "description": "Fraction of turns where envelope passed JSONSchema validation after the re-prompt loop"
          }
        }
      }
    }
  }
}
