{
  "version": 1,
  "checks": [
    {
      "name": "pytest passes",
      "command": "python3 -m pytest  -q",
      "expect": {
        "exit_code": 0
      }
    },
    {
      "name": "at least 4 tests collected",
      "command": "python3 -m pytest  --co -q",
      "expect": {
        "exit_code": 0,
        "stdout_pattern": "[4-9][0-9]* test|[1-9][0-9]+ test"
      }
    },
    {
      "name": "iso.py unchanged",
      "file_unchanged": "iso.py"
    }
  ]
}